# AWS
AWS_REGION=us-east-1
AWS_PROFILE=giftbee-dev

# GitHub MCP
GITHUB_PAT=ghp_xxxxxxxxxxxx

# Figma MCP
FIGMA_PAT=figd_xxxxxxxxxxxx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Organization / Project
MASON_ORG=giftbee
MASON_PROJECT=mason
MASON_WORKSPACE_ROOT=/home/ratheepan/workspace/giftbee

# Slack integration
# Bot token from your Slack app (xoxb-...)
MASON_SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
# Signing secret from your Slack app's Basic Information page
MASON_SLACK_SIGNING_SECRET=xxxxxxxxxxxx
# App-level token for Socket Mode (xapp-...) — optional, only for Socket Mode
MASON_SLACK_APP_TOKEN=xapp-xxxxxxxxxxxx
# Slack channels for Mason notifications and approval requests
MASON_SLACK_NOTIFICATION_CHANNEL=mason-notifications
MASON_SLACK_APPROVAL_CHANNEL=mason-approvals
# Slack user ID of the bot (U...) — used to filter bot's own messages
MASON_SLACK_AGENT_USER_ID=UXXXXXXXXXX

# Bedrock model IDs (optional overrides)
MASON_OPUS_MODEL_ID=us.anthropic.claude-opus-4-6-20250609-v1:0
MASON_SONNET_MODEL_ID=us.anthropic.claude-sonnet-4-6-20250514-v1:0

# SQS (worker pulls tasks from this queue)
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/mason-tasks

# Terraform state backend
MASON_TF_STATE_BUCKET=giftbee-tofu-state
MASON_TF_LOCK_TABLE=giftbee-tofu-locks
